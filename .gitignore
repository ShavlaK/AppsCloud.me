```gitignore
# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Virtual environments
venv/
.venv/
env/

# Dependencies
pip-tools/
*.egg-info/

# Logs
*.log

# Environment variables
.env
.env.local
*.env.*

# IDE specific
.vscode/
.idea/
*.swp
*.swo

# Coverage reports
.coverage
coverage/
htmlcov/

# Distribution / packaging
dist/
build/
*.egg
*.tar.gz
*.whl
```