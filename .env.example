# Price Updater - Environment Configuration Example
# Copy this file to .env and fill in your values

# Telegram Source Bot Token (the bot/channel you parse prices from)
SOURCE_BOT_TOKEN=your_source_bot_token_here

# Your Channel Bot Token (bot that posts to your channel)
YOUR_BOT_TOKEN=your_channel_bot_token_here

# Telegram Channel ID (can be @username or -100xxxxxx for private channels)
CHANNEL_ID=@your_channel_username

# Markup percentage to apply to parsed prices (e.g., 15 = 15%)
MARKUP_PERCENT=15

# Update interval in hours (for auto mode)
UPDATE_INTERVAL_HOURS=1

# Database path
DATABASE_PATH=data/prices.db

# Logs path
LOGS_PATH=logs/app.log

# Web server configuration
WEB_HOST=0.0.0.0
WEB_PORT=8080

# Scheduler settings (cron format: minute hour day month weekday)
# Default: every hour from 11:30 to 19:30 on weekdays
SCHEDULER_MINUTE=30
SCHEDULER_HOUR_START=11
SCHEDULER_HOUR_END=19

# Data retention (days to keep old price snapshots)
DATA_RETENTION_DAYS=90

# Enable debug mode (true/false)
DEBUG_MODE=false
